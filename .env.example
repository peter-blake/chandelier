# Chandelier — Environment Variables
# Copy this to .env and fill in values. Never commit .env to git.
# The server will throw and exit if any required variable is missing at startup.

# ─── Network ───────────────────────────────────────────────────────────────────
# "base-sepolia" for testnet | "base" for mainnet
NETWORK=base-sepolia

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ─── Exa ───────────────────────────────────────────────────────────────────────
# https://exa.ai — create account, get API key
EXA_API_KEY=

# ─── Anthropic ─────────────────────────────────────────────────────────────────
# https://console.anthropic.com — create API key
ANTHROPIC_API_KEY=

# ─── Coinbase CDP (x402 payment facilitator) ───────────────────────────────────
# https://docs.cdp.coinbase.com — create a project, generate API key
# Key name looks like: "organizations/xxx/apiKeys/xxx"
CDP_API_KEY_NAME=
# Private key is a multiline PEM — store as single line with \n literals
CDP_API_KEY_PRIVATE_KEY=

# ─── x402 Payment Facilitator URL ──────────────────────────────────────────────
# Testnet: https://x402.org/facilitator (or CDP testnet endpoint)
# Mainnet: https://x402.org/facilitator
PAYMENT_FACILITATOR_URL=https://x402.org/facilitator

# ─── Wallet Address (receiving payments) ───────────────────────────────────────
# Your Base wallet address that receives USDC payments
# Testnet: fund via QuickNode devnet USDC faucet
PAYMENT_ADDRESS=

# ─── Optional: Logging ─────────────────────────────────────────────────────────
# "development" for pretty logs | "production" for JSON-only
LOG_FORMAT=development

# ─── Test wallet (scripts/test-payment.ts only) ────────────────────────────────
# Private key of a THROWAWAY Base Sepolia wallet funded with testnet USDC.
# NEVER use a wallet holding real funds. NEVER commit this value.
TEST_WALLET_PRIVATE_KEY=
